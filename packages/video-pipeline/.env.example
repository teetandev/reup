# FFmpeg binaries (defaults: ffmpeg/ffprobe in PATH)
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# FFmpeg render settings (low-resource defaults for 2vCPU/2GB VPS)
FFMPEG_THREADS=1
FFMPEG_PRESET=ultrafast
FFMPEG_CRF=28

# Groq API for Whisper transcription
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=whisper-large-v3

# Google Gemini API for translation
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
TRANSLATION_BATCH_SIZE=50

# Audio chunking settings
MAX_CHUNK_DURATION_SEC=300
MAX_CHUNK_SIZE_MB=20

# LOCAL E2E ONLY: when true, transcription (Groq) and translation (Gemini) are
# stubbed with placeholder text so the full pipeline runs without API keys.
# FFmpeg is still required. Keep false in production.
MOCK_AI=false
