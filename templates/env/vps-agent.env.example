APP_ENV=development
NODE_ID=
NODE_TOKEN=
CONTROL_API_URL=http://localhost:8000
AGENT_PUBLIC_URL=http://localhost:8100
AGENT_PORT=8100
HEARTBEAT_INTERVAL_SECONDS=30
MAX_JOBS=1
MAX_FILE_MB=500
WORK_DIR=/var/lib/reup-agent/jobs
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
FFMPEG_THREADS=1
FFMPEG_PRESET=ultrafast
FFMPEG_CRF=28
GROQ_API_KEY=
GEMINI_API_KEY=
