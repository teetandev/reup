APP_ENV=development
NODE_ID=
NODE_TOKEN=
CONTROL_API_URL=http://localhost:8000
# For GitHub Codespace workers, use:
#   AGENT_PUBLIC_URL=https://<codespace-name>-8100.app.github.dev
# For VPS (legacy), use the server's public IP/domain.
AGENT_PUBLIC_URL=http://localhost:8100
AGENT_PORT=8100
HEARTBEAT_INTERVAL_SECONDS=30
MAX_JOBS=1
MAX_FILE_MB=500
# Codespace: /workspaces/reup/.worker/jobs
# VPS:       /var/lib/reup-agent/jobs
WORK_DIR=/var/lib/reup-agent/jobs
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
# Codespace (2-4 vCPU): 3 threads works well. VPS: adjust to core count.
FFMPEG_THREADS=1
FFMPEG_PRESET=ultrafast
FFMPEG_CRF=28
# Pipeline secrets/config (Phase 10: agent runs packages/video-pipeline in-process).
# Keep these out of source control. Never log them.
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional: override video-pipeline package location for non-monorepo deploys.
# VIDEO_PIPELINE_PATH=/opt/reup/packages/video-pipeline
# LOCAL E2E / CODESPACE ONLY: stub transcription + translation so the pipeline
# runs without real GROQ/GEMINI keys (FFmpeg still required). Leave false in production.
MOCK_AI=false
